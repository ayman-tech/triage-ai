# ── Google Gemini (required) ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-gemini-api-key-here   # alternative name accepted by the SDK

# Model to use for all agents (default: gemini-2.0-flash)
GEMINI_CHAT_MODEL=gemini-2.0-flash

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
# Native Google ADK integration — configure_google_adk() is called on startup.
# All ADK LlmAgent calls are automatically traced when tracing is enabled.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=triage-ai

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/complaints

# ── HuggingFace embeddings (local, free) ─────────────────────────────────────
# Model is downloaded on first use (~90 MB). Runs on CPU by default.
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HF_DEVICE=cpu   # cpu | cuda | mps

# ── Jira integration (optional) ──────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=KAN
JIRA_ASSIGNEE_ID=

# ── ElevenLabs voice intake (optional) ───────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ── Intake LangSmith opt-in (optional) ───────────────────────────────────────
# Intake chat turns are NOT traced by default to protect consumer PII.
# Set to true only in non-production / testing environments.
TRACE_INTAKE_TO_LANGSMITH=false
